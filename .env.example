# ============================================
# SLACK EMOJI REACTOR BOT — Configuration
# ============================================
# Copie ce fichier en .env et remplis les valeurs
#   cp .env.example .env
# ============================================

# Bot User OAuth Token (xoxb-...)
# Trouvable dans : api.slack.com/apps > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Signing Secret
# Trouvable dans : api.slack.com/apps > Basic Information
SLACK_SIGNING_SECRET=your-signing-secret-here

# App-Level Token pour Socket Mode (xapp-...)
# Trouvable dans : api.slack.com/apps > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-your-app-token-here

# Emoji cible (sans les ::) — ex: partyparrot, fire, tada
TARGET_EMOJI=partyparrot

# (Optionnel) ID de l'utilisateur cible pour l'auto-react
# À chaque message de cette personne, le bot réagit avec l'emoji + envoie un DM
# Pour trouver l'ID : clic sur le profil Slack > ⋮ > Copy member ID
# Laisser vide pour désactiver cette fonctionnalité
TARGET_USER_ID=

# (Optionnel) Message personnalisé envoyé en DM à la cible
# Laisser vide pour utiliser le message par défaut
TARGET_USER_MESSAGE=

# (Optionnel) Clé API Giphy pour médias dynamiques
# Laisser vide pour utiliser la banque locale media-bank.json
GIPHY_API_KEY=

# (Optionnel) Tag Giphy pour filtrer les GIFs
GIPHY_TAG=funny
